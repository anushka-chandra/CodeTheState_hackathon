# PLANRAUM environment — all optional. The app runs fully without any of these.

# Backend API base URL. When set, real uploads POST to the FastAPI /extract
# endpoint; unset, the app uses the local mock simulation (demo-safe default).
# VITE_API_URL=http://localhost:8000

# Cesium ion token — ONLY needed if you swap the MapLibre viewer for the
# optional CesiumJS globe (see src/viewer/). MapLibre needs no key at all.
# VITE_CESIUM_TOKEN=
