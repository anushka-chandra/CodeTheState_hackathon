# PLANRAUM — server-side env for the Vercel extraction function (api/extract.ts).
# Copy to .env for local `vercel dev`. On Vercel, set these in
# Project → Settings → Environment Variables. The real .env is gitignored and
# these values are NEVER exposed to the browser (no VITE_ prefix).

# Required: API key for the OpenAI-compatible gateway.
OPENAI_API_KEY=

# Gateway base URL (OpenAI-compatible /v1). Defaults to OpenAI if unset.
OPENAI_BASE_URL=https://litellm-kommone.genai.govdigital.de/v1

# Optional: override the vision model. Defaults to Qwen3-VL on the gateway.
# OPENAI_MODEL=stackit-qwen-qwen3-vl-235b-a22b-instruct-fp8
